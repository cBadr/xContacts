# ===== xContacts production environment =====
# Copy this file to .env and adjust values. The server loads the one in /server/.env
# automatically; for the root-level deploy script you can keep both in sync.

# Bind address and port. On a VPS usually 0.0.0.0 so that the reverse-proxy
# (Caddy / nginx) or the firewall can reach it.
HOST=0.0.0.0
PORT=5174

# Public URL used for OAuth callbacks and CORS. MUST match what you register
# in Google Cloud / Azure and what users type in the browser.
#   http://203.0.113.10:5174        (bare IP, no HTTPS — for quick tests only)
#   https://xcontacts.example.com   (recommended — behind Caddy/nginx with TLS)
PUBLIC_URL=https://xcontacts.example.com

# If you run behind nginx/Caddy/Cloudflare, keep this at 1 so rate-limit
# sees the real client IP from X-Forwarded-For.
TRUST_PROXY=1

# Leave blank in single-origin production (client served by the same Node process).
# Set to a comma-separated list only if you serve the frontend from a different domain.
CORS_ORIGIN=

# Optional — point to an absolute path for the built SPA. Defaults to ./client/dist
# CLIENT_DIR=/opt/xcontacts/client/dist
# SERVE_CLIENT=true

NODE_ENV=production
XC_DATA_DIR=./server/data
MAX_FETCH_PER_FOLDER=5000

# ===== OAuth2 credentials =====
# Redirect URI that must be registered in the provider console:
#   <PUBLIC_URL>/api/oauth/callback
# Leave OAUTH_REDIRECT_BASE unset unless it differs from PUBLIC_URL.
OAUTH_REDIRECT_BASE=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
