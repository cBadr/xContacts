# Caddy config — automatic HTTPS via Let's Encrypt for leads.orcax.click
leads.orcax.click {
    encode zstd gzip

    # SSE streams (scan progress) must NOT be buffered.
    reverse_proxy 127.0.0.1:5174 {
        flush_interval -1
        transport http {
            read_timeout 10m
            response_header_timeout 10m
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    log {
        output file /var/log/caddy/leads.orcax.click.log
        format json
    }
}
