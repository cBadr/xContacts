# nginx reverse-proxy for xContacts — leads.orcax.click
# ثبّت في /etc/nginx/sites-available/leads.orcax.click ثم فعّله.

server {
    listen 80;
    listen [::]:80;
    server_name leads.orcax.click;

    # Let's Encrypt ACME
    location /.well-known/acme-challenge/ { root /var/www/html; }

    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name leads.orcax.click;

    ssl_certificate     /etc/letsencrypt/live/leads.orcax.click/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/leads.orcax.click/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    client_max_body_size 4m;

    location / {
        proxy_pass http://127.0.0.1:5174;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "";

        # Critical for scan progress (Server-Sent Events)
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}
