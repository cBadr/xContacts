PORT=5174
CORS_ORIGIN=http://localhost:5173
MAX_FETCH_PER_FOLDER=5000

# OAuth2 — base URL that the provider redirects to after sign-in.
# Must match the redirect URI you registered in the provider console.
OAUTH_REDIRECT_BASE=http://localhost:5174

# Google OAuth2 — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID of type "Web application".
# Authorized redirect URI: http://localhost:5174/api/oauth/callback
# Enable Gmail API on the project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 — https://entra.microsoft.com → App registrations → New
# Redirect URI: http://localhost:5174/api/oauth/callback (Web platform)
# API permissions: IMAP.AccessAsUser.All (Office 365 Exchange Online), offline_access, email, profile
# For personal accounts use tenant "common" (already set in code).
# Client secret optional for public clients but recommended for confidential.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
