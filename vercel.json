{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix client install --include=dev && npm --prefix client run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --ignore-scripts",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://REPLACE-WITH-YOUR-BACKEND.example.com/api/:path*" }
  ]
}
